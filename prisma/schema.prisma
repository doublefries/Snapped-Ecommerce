// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @db.Decimal(10, 2)
  images         String[] // Array of image URLs (first = cover, second = hover, rest = gallery)
  variantImages  Json?    // Optional: { "variantValue": "imageUrl" } for variant-specific images
  category       String?
  inStock     Boolean  @default(true)
  stockQty    Int      @default(0)
  variants    ProductVariant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorName  String   @default("DEFAULT") // e.g., "NAVY" (or "DEFAULT" for non-color products)
  colorValue String   @default("default") // e.g., "navy" (or "default" for non-color products)
  sizeName   String   @default("OS") // e.g., "S", "M", "L", "XL" (or "OS" for one-size)
  sizeValue  String   @default("os") // e.g., "s", "m", "l", "xl" (or "os" for one-size)
  stockQty  Int      @default(0)
  createdAt DateTime @default(now())
  
  @@unique([productId, colorValue, sizeValue])
  @@index([productId, colorValue])
  @@index([productId, sizeValue])
}

model Order {
  id              String      @id @default(cuid())
  stripeSessionId String?     @unique
  email           String
  total           Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  shippingAddress Json?       // Store as JSON for flexibility
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  productName   String   // Snapshot of product name at time of order
  variantName   String?  // e.g., "NAVY", "BROWN"
  quantity      Int
  price         Decimal  @db.Decimal(10, 2) // Snapshot of price at time of order
  createdAt     DateTime @default(now())
}
